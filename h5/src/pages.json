      { "pagePath": "pages/checkin/index", "text": "打卡", "iconPath": "static/tabbar/checkin.png", "selectedIconPath": "static/tabbar/checkin-active.png" },
      { "pagePath": "pages/training/index", "text": "训练", "iconPath": "static/tabbar/training.png", "selectedIconPath": "static/tabbar/training-active.png" },
      { "pagePath": "pages/ai-tools/index", "text": "AI", "iconPath": "static/tabbar/ai.png", "selectedIconPath": "static/tabbar/ai-active.png" },
      { "pagePath": "pages/profile/index", "text": "我的", "iconPath": "static/tabbar/profile.png", "selectedIconPath": "static/tabbar/profile-active.png" }
    ]
  },
  "easycom": {
    "autoscan": true,
    "custom": {
      "^uni-(.*)": "@dcloudio/uni-ui/lib/uni-$1/uni-$1.vue"
