# Flask
FLASK_ENV=production
FLASK_DEBUG=False
SECRET_KEY=change-to-random-string

# 数据库
DATABASE_URL=mysql://eloquence_user:strong_password@rm-xxx.mysql.rds.aliyuncs.com:3306/eloquence_camp

# JWT
JWT_SECRET_KEY=change-to-random-string
JWT_ACCESS_TOKEN_EXPIRES=86400

# 阿里云 OSS
OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
OSS_ACCESS_KEY_ID=your-access-key-id
OSS_ACCESS_KEY_SECRET=your-access-key-secret
OSS_BUCKET_NAME=eloquence-camp-prod

# 阿里云百炼 (Qwen)
DASHSCOPE_API_KEY=your-dashscope-api-key
QWEN_TEXT_MODEL=qwen3-max
QWEN_FEEDBACK_MODEL=qwen3-flash

# 阿里云智能语音交互
ALIYUN_SPEECH_APP_KEY=your-speech-app-key
ALIYUN_SPEECH_ACCESS_KEY_ID=your-speech-ak-id
ALIYUN_SPEECH_ACCESS_KEY_SECRET=your-speech-ak-secret

# 微信小程序
WECHAT_APPID=your-miniprogram-appid
WECHAT_SECRET=your-miniprogram-secret
